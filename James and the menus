import sys

def solve():
   
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
    N = int(input_data[0])
    M = int(input_data[1])
    
    menus = []
    ptr = 2
    for i in range(N):
        
        menus.append([int(x) for x in input_data[ptr : ptr + M]])
        ptr += M
        
    max_prices = [0] * M
    for j in range(M):
        current_max = -1
        for i in range(N):
            if menus[i][j] > current_max:
                current_max = menus[i][j]
        max_prices[j] = current_max
        
    best_menu_idx = -1
    max_good_count = -1
    max_total_price = -1
    
    for i in range(N):
        good_count = 0
        current_total = 0
        for j in range(M):
            current_total += menus[i][j]
           
            if menus[i][j] == max_prices[j]:
                good_count += 1
        
        if good_count > max_good_count:
            max_good_count = good_count
            max_total_price = current_total
            best_menu_idx = i + 1
        elif good_count == max_good_count:
            if current_total > max_total_price:
                max_total_price = current_total
                best_menu_idx = i + 1
                
    print(best_menu_idx)

if __name__ == "__main__":
    solve()

