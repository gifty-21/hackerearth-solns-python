import sys

def solve():
    
    line = sys.stdin.readline()
    if not line:
        return
    
    R, C, r, c = map(int, line.split())
    
    for i in range(R):
        row_output = []
        
        for j in range(C):
          
            distance = max(abs(i - r), abs(j - c))
            row_output.append(str(distance))
        
        sys.stdout.write(" ".join(row_output) + "\n")

if __name__ == "__main__":
    solve()
