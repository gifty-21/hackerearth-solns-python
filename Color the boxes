import sys

def solve():
    
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
    n = int(input_data[0])
    m = int(input_data[1])
    
    MOD = 1000000007
    
    ans = 1
    for i in range(1, m + 1):
        ans = (ans * i) % MOD
        
    print(ans)

if __name__ == "__main__":
    solve()
