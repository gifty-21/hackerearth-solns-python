import sys

def solve():
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
    t = int(input_data[0])
    pointer = 1
    results = []
    
    for _ in range(t):
        n = int(input_data[pointer])
        s = input_data[pointer + 1]
        pointer += 2
        
        total_a = s.count('A')
        
        min_changes = total_a
        
        current_a = 0
        current_b = 0
        
        for char in s:
            if char == 'A':
                current_a += 1
            else:
                current_b += 1
            
            changes = current_b + (total_a - current_a)
            if changes < min_changes:
                min_changes = changes
                
        results.append(str(min_changes))
    
    sys.stdout.write("\n".join(results) + "\n")

if __name__ == "__main__":
    solve()
