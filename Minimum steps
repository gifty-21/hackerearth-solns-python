import sys
import bisect

def get_lis_length(arr):
    tails = []
    for x in arr:
        idx = bisect.bisect_left(tails, x)
        if idx < len(tails):
            tails[idx] = x
        else:
            tails.append(x)
    return len(tails)

def solve():
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
    n = int(input_data[0])
    arr = list(map(int, input_data[1:]))
    
    if n <= 1:
        print(0)
        return

    lis_len = get_lis_length(arr)
    
    
    reversed_arr = [-x for x in arr]
    lds_len = get_lis_length(reversed_arr)
 
    print(n - max(lis_len, lds_len))

if __name__ == "__main__":
    solve()
