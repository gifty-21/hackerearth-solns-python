import sys

def solve():
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
    N = int(input_data[0])
    A = list(map(int, input_data[1:]))
    
    filtered_A = [x for x in A if x != 0]
    
    if not filtered_A:
        print(0)
        return
    
    ops = 1
    for i in range(1, len(filtered_A)):
        if filtered_A[i] != filtered_A[i-1]:
            ops += 1
            
    print(ops)

if __name__ == "__main__":
    solve()
