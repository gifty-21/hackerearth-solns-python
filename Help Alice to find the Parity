import sys

def solve():
    
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
    l = int(input_data[0])
    r = int(input_data[1])
    
    odds_up_to_r = (r + 1) // 2
    odds_up_to_l_minus_1 = l // 2
    
    count_of_odds = odds_up_to_r - odds_up_to_l_minus_1
    
   
    if count_of_odds % 2 != 0:
        print("odd")
    else:
        print("even")

if __name__ == "__main__":
    solve()
