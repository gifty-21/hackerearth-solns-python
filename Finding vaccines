import sys

def solve():
   
    try:
        line1 = sys.stdin.readline()
        if not line1: return
        n = int(line1.strip())
        
        v_len = int(sys.stdin.readline().strip())
        virus_rna = sys.stdin.readline().strip()
    except EOFError:
        return

    v_g = virus_rna.count('G')
    v_c = virus_rna.count('C')

    max_interaction = -1
    best_vaccine_index = -1

    for i in range(1, n + 1):
      
        vac_len = int(sys.stdin.readline().strip())
        vac_rna = sys.stdin.readline().strip()
        
        vac_g = vac_rna.count('G')
        vac_c = vac_rna.count('C')
        
        current_interaction = (v_g * vac_c) + (v_c * vac_g)
        
        if current_interaction > max_interaction:
            max_interaction = current_interaction
            best_vaccine_index = i

    print(best_vaccine_index)

if __name__ == "__main__":
    solve()
