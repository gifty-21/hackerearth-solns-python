import sys

def solve():
  
    input_data = sys.stdin.read().split()
    if not input_data:
        return
    
    n = int(input_data[0])
    k = int(input_data[1])
    arr = list(map(int, input_data[2:]))
    
    sorted_arr = sorted(arr)
    
    specialty_sum = 0
    
    for x in arr:
     
        import bisect
        idx = bisect.bisect_right(sorted_arr, x)
        count_greater = n - idx
        
        if count_greater >= k:
            specialty_sum += x
            
    print(specialty_sum)

if __name__ == "__main__":
    solve()
